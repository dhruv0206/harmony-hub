# ---------------------------------------------------------------------------
# Provider Harmony Hub — Backend (FastAPI) environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
#
# Legend:  [REQUIRED]  must set for the backend to function
#          [OPTIONAL]  safe to leave blank for local dev today
#          [FUTURE]    placeholder for later phases — leave blank
# ---------------------------------------------------------------------------

# === Runtime ================================================================
ENVIRONMENT=development        # development | staging | production
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
PORT=8000

# === CORS ===================================================================
# Comma-separated allowed origins for browser requests.
# Includes common Vite dev ports. Add your production frontend URL when deploying.
CORS_ORIGINS=http://localhost:8080,http://localhost:5173,http://localhost:3000


# === Supabase ===============================================================

# [REQUIRED] Public project URL. Used for JWKS fetching + Edge Function calls.
SUPABASE_URL=https://haqtcycfkkziblafkonr.supabase.co

# [OPTIONAL] Anon key (public). Dashboard → Settings → API Keys → `anon` `public`.
# Used as a fallback `apikey` header when invoking Edge Functions. If blank,
# falls back to the service role key.
SUPABASE_ANON_KEY=

# [REQUIRED] Service role key (secret). Dashboard → Settings → API Keys →
# `service_role` → click "Reveal". BYPASSES RLS. Never expose to frontend.
# Used for CSV import admin inserts and as fallback auth for Edge Functions.
SUPABASE_SERVICE_ROLE_KEY=

# [OPTIONAL] Legacy HS256 signing secret. Modern Supabase projects use ES256
# and auto-fetch public keys from /auth/v1/.well-known/jwks.json — leave blank.
# Only fill if your project still uses legacy HS256 and ES256 isn't working.
# Dashboard → Settings → JWT Keys → Legacy section.
SUPABASE_JWT_SECRET=

# [FUTURE] Direct Postgres connection string (asyncpg). Not used today.
# When needed, prefer Transaction mode (port 6543, PgBouncer-compatible):
#   postgresql://postgres.<ref>:<password>@<host>:6543/postgres
DATABASE_URL=


# === Google APIs ============================================================

# [REQUIRED] Single Google Cloud API key used server-side. Enable in
# Google Cloud Console → APIs & Services → Library:
#   • Geocoding API
#   • Places API (address autocomplete + details)
# Then restrict the key: Credentials → your key → Edit → API restrictions.
GOOGLE_API_KEY=


# === Caching / Rate Limiting ================================================

# [FUTURE] In-memory today. Swap to Redis at deploy time for multi-instance
# correctness (rate-limit state + geocode cache shared across Cloud Run
# instances).
# REDIS_URL=redis://localhost:6379/0
