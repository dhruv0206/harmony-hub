# ---------------------------------------------------------------------------
# Provider Harmony Hub — Backend (FastAPI) environment variables
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- Runtime -----------------------------------------------------------------
ENVIRONMENT=development        # development | staging | production
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
PORT=8000

# --- CORS --------------------------------------------------------------------
# Comma-separated list of allowed origins for browser requests.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Supabase ----------------------------------------------------------------
# Public project URL (safe to expose; also used by the frontend).
SUPABASE_URL=https://haqtcycfkkziblafkonr.supabase.co

# Anon key — used for user-scoped calls that should respect RLS.
SUPABASE_ANON_KEY=

# Service role key — bypasses RLS. NEVER expose to the frontend or commit.
# Only used server-side for admin operations that genuinely require it.
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret — used to verify Supabase-issued access tokens in FastAPI auth
# middleware. Find it in Supabase Dashboard → Settings → API → JWT Secret.
SUPABASE_JWT_SECRET=

# Direct Postgres connection string for asyncpg pool. Prefer the pooled
# connection (port 6543, PgBouncer transaction mode) for serverless workloads.
# Format: postgresql://postgres.<ref>:<password>@<host>:6543/postgres
DATABASE_URL=

# --- Google APIs -------------------------------------------------------------
# Google Places API key (Geocoding + Places Autocomplete + Place Details).
# Restrict by API + referrer/IP in Google Cloud Console.
GOOGLE_PLACES_API_KEY=

# --- Caching / Rate Limiting -------------------------------------------------
# In-memory today. Swap to Redis at deploy time for multi-instance correctness.
# REDIS_URL=redis://localhost:6379/0
